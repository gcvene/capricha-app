# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://app.capricha.app.br
APP_LANGUAGE=portuguese-br

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=
DB_NAME=capricha
DB_USERNAME=
DB_PASSWORD=

# ─── Encryption (AES-256-CBC) ─────────────────────────────────────────────────
# Generate with: php -r "echo bin2hex(random_bytes(32));"
CRYPTO_KEY=

# ─── Asaas ───────────────────────────────────────────────────────────────────
# Obtido em: Painel Asaas → Minha Conta → Integração → Gerar API Key
ASAAS_API_KEY=
# Mesmo token configurado em: Painel Asaas → Integrações → Webhooks → access_token
ASAAS_WEBHOOK_TOKEN=

# ─── Meta / WhatsApp Cloud API ───────────────────────────────────────────────
# Business Manager → WhatsApp → Configuração → Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=
# Business Manager → Configurações do Sistema → Tokens de Acesso de Sistema (não expira)
WHATSAPP_ACCESS_TOKEN=
# Definido por você ao cadastrar o webhook no Meta App Dashboard
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret: Meta App Dashboard → Configurações → Básico → Segredo do Aplicativo
WHATSAPP_APP_SECRET=

# ─── Resend (email transacional) ─────────────────────────────────────────────
# Obtido em: resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@capricha.app.br
